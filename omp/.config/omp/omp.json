{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "palette": {
    "black": "#262B44",
    "blue": "#4B95E9",
    "green": "#59C9A5",
    "grey": "#8a8a8a",
    "orange": "#F07623",
    "red": "#D81E5B",
    "white": "#E0DEF4",
    "yellow": "#F3AE35",
    "base": "#191724",
    "surface": "#1f1d2e",
    "overlay": "#26233a",
    "muted": "#6e6a86",
    "subtle": "#908caa",
    "text": "#e0def4",
    "love": "#eb6f92",
    "gold": "#f6c177",
    "rose": "#ebbcba",
    "pine": "#31748f",
    "foam": "#9ccfd8",
    "iris": "#c4a7e7",
    "highlight_low": "#21202e",
    "highlight_med": "#403d52",
    "highlight_high": "#524f67"
  },
  "secondary_prompt": {
    "template": "❯❯ ",
    "foreground": "p:iris",
    "background": "transparent"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "plain",
          "foreground": "p:text",
          "template": "{{ if .SSHSession }}<p:iris>(</>{{.HostName}}<p:iris>)</> {{ end }}"
        },
        {
          "options": {
            "edge_format": "<p:text>%s</>",
            "folder_separator_template": "<p:iris>/</>",
            "style": "agnoster_full"
          },
          "template": "{{ .Path }}",
          "foreground": "p:iris",
          "background": "transparent",
          "type": "path",
          "style": "plain"
        },
        {
          "options": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": false
          },
          "template": " <p:muted>on</> {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}</><p:iris>{{ if .LatestTag }} <p:muted>lt</> <p:pine>{{ .LatestTag }}{{ end }}</>",
          "foreground": "p:iris",
          "background": "transparent",
          "type": "git",
          "style": "plain",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:gold{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:love{{ end }}",
            "{{ if gt .Ahead 0 }}p:rose{{ end }}"
          ]
        },
        {
          "type": "docker",
          "style": "plain",
          "foreground": "p:blue",
          "template": "{{ if or (eq .Context \"desktop-linux\") (eq .Context \"default\") }}{{else}}  {{.Context}}{{ end }}"
        },
        {
          "options": {
            "always_enabled": false
          },
          "template": "  {{ .String }}",
          "foreground": "p:love",
          "background": "transparent",
          "type": "status",
          "style": "plain"
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "options": {
            "cache_duration": "30m"
          },
          "template": "  {{ .Full }}",
          "foreground": "green",
          "background": "transparent",
          "type": "node",
          "style": "plain"
        },
        {
          "options": {
            "cache_duration": "30m",
            "parse_mod_file": true
          },
          "template": "  {{ .Full }}",
          "foreground": "blue",
          "background": "transparent",
          "type": "go",
          "style": "plain"
        },
        {
          "options": {
            "cache_duration": "30m"
          },
          "template": "  {{ .Full }}{{ if .Venv }} ({{ .Venv }}){{end}}",
          "foreground": "yellow",
          "background": "transparent",
          "type": "python",
          "style": "plain"
        },
        {
          "template": " took <red>{{ .FormattedMs }}</>",
          "type": "executiontime",
          "style": "plain"
        },
        {
          "template": " at <p:foam><b>{{ .CurrentDate | date \"15:04:05\" }}</b></>",
          "foreground": "white",
          "background": "transparent",
          "type": "time",
          "style": "plain"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": " ❯",
          "foreground": "p:iris",
          "background": "transparent",
          "type": "text",
          "style": "plain"
        }
      ]
    }
  ],
  "tooltips": [
    {
      "options": {
        "display_default": true
      },
      "leading_diamond": "",
      "trailing_diamond": "",
      "template": "  {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} ",
      "foreground": "p:orange",
      "type": "aws",
      "style": "plain",
      "tips": [
        "aws"
      ]
    }
  ]
}
